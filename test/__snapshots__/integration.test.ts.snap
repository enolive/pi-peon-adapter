// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`pi peon adapter integration > writes debug log lines for received events and sink handoff 1`] = `
"<timestamp> [info] hook=session_start phase=received cwd=/integration/project reason=startup has_ui=true
<timestamp> [info] peon_path=<peon> event=SessionStart decision=send cwd=/integration/project session_id=pi-default-session
<timestamp> [info] peon_path=<peon> event=SessionStart decision=child_close code=0
<timestamp> [info] hook=tool_execution_end phase=received cwd=/integration/project tool=read is_error=true
<timestamp> [warn] hook=tool_execution_end decision=skip reason=non_bash_tool cwd=/integration/project tool=read
<timestamp> [info] hook=tool_execution_end phase=received cwd=/integration/project tool=bash is_error=true
<timestamp> [info] peon_path=<peon> event=PostToolUseFailure decision=send cwd=/integration/project session_id=pi-default-session
<timestamp> [info] peon_path=<peon> event=PostToolUseFailure decision=child_close code=0
"
`;

exports[`pi peon adapter integration > writes default session payloads to the resolved peon executable 1`] = `
[
  {
    "cwd": "/integration/project",
    "hook_event_name": "SessionStart",
    "session_id": "pi-default-session",
    "source": "startup",
  },
  {
    "cwd": "/integration/project",
    "hook_event_name": "UserPromptSubmit",
    "session_id": "pi-default-session",
  },
  {
    "cwd": "/integration/project",
    "hook_event_name": "Stop",
    "session_id": "pi-default-session",
  },
  {
    "cwd": "/integration/project",
    "error": "bash failed",
    "hook_event_name": "PostToolUseFailure",
    "session_id": "pi-default-session",
    "tool_name": "Bash",
  },
]
`;
